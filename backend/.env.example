# Saathi — Environment Variables
# Copy this file to .env and fill in your keys.

# ─── Required: AI API Keys ───
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Add Groq API key for 5-10x faster STT (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ─── Database ───
DATABASE_URL=postgresql://user:password@host:5432/saathi

# ─── Auth — OTP Provider ───
# Choose "msg91" or "twilio"
OTP_PROVIDER=twilio

# MSG91 (if OTP_PROVIDER=msg91)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# Twilio (if OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_ID=your_twilio_verify_service_id

# ─── Auth — Google Sign-In ───
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Auth — JWT ───
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY_DAYS=7
